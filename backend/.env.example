# Copia este archivo a ".env" para desarrollo local, o configura estas
# mismas variables en Railway (Settings -> Variables).

# Clave que usara todo el equipo de Pricing para entrar al panel /admin
ADMIN_PASSWORD=cambia-esta-clave

# Clave interna para firmar la sesion (cualquier texto largo y aleatorio)
SECRET_KEY=cambia-esta-clave-tambien
